# KFG Executive Dashboard Configuration
# Copy this file to .env and fill in your values

# Azure AD App Registration - Client ID
# Get this from https://portal.azure.com → App registrations
AZURE_CLIENT_ID=your-client-id-here

# Azure AD Tenant ID (optional - defaults to 'organizations' for multi-tenant)
# For single-tenant (recommended), use your organization's tenant ID
AZURE_TENANT_ID=your-tenant-id-here

# SharePoint Site URL
SHAREPOINT_SITE_URL=https://kfguae.sharepoint.com/sites/ExecutiveDashboard
